NODE_ENV=development
PORT=3000

# PostgreSQL connection string used by Prisma.
DATABASE_URL="postgresql://neondb_owner:npg_eE2knyVQblp8@ep-wandering-mode-aoyw018y-pooler.c-2.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# JWT secrets must be long, random values in deployed environments.
JWT_ACCESS_SECRET=replace-with-a-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-a-long-random-refresh-token-secret
